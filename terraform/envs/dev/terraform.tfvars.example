# Copy to terraform.tfvars (gitignored) and fill in your values.

region      = "eu-central-1"
github_repo = "NiceXD1204/expense-tracker"

# node_instance_types = ["t3.medium"]
# node_desired_size   = 1
# node_min_size       = 1
# node_max_size       = 2

# Optional: Slack notifications for pod crash-loops and other warning/critical
# alerts (Alertmanager). The webhook URL itself is NOT a Terraform variable -
# create it as a Kubernetes Secret directly in the cluster first (see
# expense-tracker-infra/README.md), then flip this on.
# enable_slack_alerts = true

domain_name       = "expensetracker.skin"
letsencrypt_email = "you@example.com"

slack_webhook_url = "https://hooks.slack.com/services/REPLACE/WITH/REAL"
